{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window. SECURITY NOTE: shell:allow-open can open arbitrary URIs; Tauri shell plugin does not yet support URI-scheme scoping in capabilities JSON. Rust callers must validate URIs start with 'http:' or 'https:' before invoking shell::open.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "dialog:allow-open",
    "dialog:allow-save",
    "notification:default",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "fs:default",
    "fs:allow-read-text-file",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$DOCUMENT/BecomeAnAuthor/**" },
        { "path": "$HOME/Documents/BecomeAnAuthor/**" },
        { "path": "$APPDATA/BecomeAnAuthor/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$DOCUMENT/**" },
        { "path": "$HOME/Documents/**" },
        { "path": "$APPDATA/BecomeAnAuthor/**" }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$DOCUMENT/**" },
        { "path": "$HOME/Documents/**" },
        { "path": "$APPDATA/BecomeAnAuthor/**" }
      ]
    },
    "shell:default",
    "shell:allow-open",
    "log:default",
    "updater:default",
    "process:allow-restart"
  ]
}
