# Google OAuth client ID (Desktop App client from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Google OAuth client secret — used ONLY by the Rust backend (google_oauth.rs).
# NEVER prefix with NEXT_PUBLIC_: that would inline the value into the JS bundle.
# Set this as a plain server-side env var; the backend reads it via std::env::var("GOOGLE_CLIENT_SECRET").
GOOGLE_CLIENT_SECRET=

# Optional: enable bundle analysis for Next build
# ANALYZE=true
